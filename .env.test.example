# Copy this to .env.test and fill in your values.
# .env.test is gitignored — never commit real credentials.

# The running netlify dev URL
TEST_BASE_URL=http://localhost:8888

# Supabase (staging project — never production)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # setup/teardown only

# Test accounts (must exist in the staging Supabase project)
TEST_ADMIN_EMAIL=admin@your-staging-project.com
TEST_ADMIN_PASSWORD=your-admin-password
TEST_CLIENT_EMAIL=client@your-staging-project.com
TEST_CLIENT_PASSWORD=your-client-password

# Optional: second client for cross-tenant isolation tests
# TEST_CLIENT2_EMAIL=client2@your-staging-project.com
# TEST_CLIENT2_PASSWORD=your-client2-password

# Known ZIP codes configured in staging service area
TEST_IN_ZONE_ZIP=30301
TEST_OUT_OF_ZONE_ZIP=10001
TEST_EXCLUDED_ZIP=30399
TEST_UNAVAILABLE_ZIP=30350

# Secret for the test-only lookup endpoint
# Must match TEST_LOOKUP_SECRET in your netlify dev .env
TEST_LOOKUP_SECRET=a-long-random-secret-for-test-endpoints

# These must also be set when running netlify dev for tests:
#   NODE_ENV=test
#   ENABLE_TEST_ENDPOINTS=true
#   TEST_LOOKUP_SECRET=<same value as above>
