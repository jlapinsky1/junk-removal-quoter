# Google Maps API Key (client-side — distance matrix, geocoding for service-area check)
VITE_GOOGLE_MAPS_API_KEY=

# Google Maps API Key (server-side Netlify functions — can be the same key or a restricted one)
GOOGLE_MAPS_API_KEY=

# Service area configuration
# Set center coordinates to your dispatch location.
# Addresses within radiusMiles will be accepted; others will be shown an out-of-area message.
SERVICE_AREA_CENTER_LAT=
SERVICE_AREA_CENTER_LNG=
SERVICE_AREA_RADIUS_MILES=30

# Mirror of the above for the Vite client bundle (used for client-side pre-check)
VITE_SERVICE_AREA_CENTER_LAT=
VITE_SERVICE_AREA_CENTER_LNG=
VITE_SERVICE_AREA_RADIUS_MILES=30

# Optional ZIP-code overrides (comma-separated, no spaces)
# Allowlist: serve these ZIPs even if they fall outside the radius
SERVICE_AREA_SERVICEABLE_ZIPS=
VITE_SERVICE_AREA_SERVICEABLE_ZIPS=

# Blocklist: reject these ZIPs even if they fall inside the radius
SERVICE_AREA_EXCLUDED_ZIPS=
VITE_SERVICE_AREA_EXCLUDED_ZIPS=

# Anthropic API Key (for AI photo analysis - used by Netlify function)
ANTHROPIC_API_KEY=

# Supabase (required for production mode)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Resend (for signup confirmation emails)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Cloudflare Turnstile (optional — uploads work without it)
VITE_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
