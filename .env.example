# Google Maps Distance Matrix API Key (optional)
# If not set, you can manually enter distance to landfill
VITE_GOOGLE_MAPS_API_KEY=

# Anthropic API Key (for AI photo analysis - used by Netlify function)
ANTHROPIC_API_KEY=

# Supabase (required for production mode)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Cloudflare Turnstile (optional — uploads work without it)
VITE_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
